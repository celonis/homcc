#!/usr/bin/make -f
# See debhelper(7) and /usr/share/doc/python3/README.PyDist

export PYBUILD_NAME=homcc

%:
	dh $@ --with python3 --buildsystem=pybuild

# pybuild stages the whole distribution under debian/python3-homcc. Point
# dh_install there so the per-package *.install files can split it into
# homcc / homccd / python3-homcc-common.
override_dh_install:
	dh_install --sourcedir=debian/python3-homcc

# debian/python3-homcc is pybuild's staging dir, not a declared package, so
# dh_clean does not remove it. Clean it up explicitly.
execute_after_dh_clean:
	rm -rf debian/python3-homcc
